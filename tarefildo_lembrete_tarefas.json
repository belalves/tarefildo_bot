      "id": "85b91b5a-d790-4910-8110-ebdebd549767",
      "name": "Tem Tarefas?1",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        2048,
        544
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst grouped = {};\n\nfor (const item of items) {\n  const wid = item.json.whatsapp_id;\n  const canais = item.json.canais_ativos || [];\n  if (!grouped[wid]) grouped[wid] = { whatsapp_id: wid, canais, tarefas: [], ids: [] };\n  grouped[wid].tarefas.push(item.json.titulo);\n  grouped[wid].ids.push(item.json.id);\n}\n\nconst resultados = [];\n\nObject.values(grouped).forEach(data => {\n  const lista = data.tarefas.map((t, i) => `${i+1}. ${t}`).join('\\n');\n  const qtd = data.tarefas.length;\n  let msg;\n  if (qtd === 1) {\n    msg = `Passando pra lembrar: '${data.tarefas[0]}' eh pra hoje. Nao deixa virar bola de neve 👀`;\n  } else if (qtd <= 3) {\n    msg = `Fala, aqui eh o Tarefildo. ${qtd} pendencias pra hoje:\\n\\n${lista}\\n\\nBora resolver antes que vire colecao ☕`;\n  } else {\n    msg = `Rapaz... ${qtd} tarefas pra hoje 😬\\n\\n${lista}\\n\\nConfia no Tarefildo. Bora la!`;\n  }\n\n  const wid = data.whatsapp_id;\n  const canais = data.canais;\n\n  // Detectar canal pelo formato do whatsapp_id\n  if (wid.includes('@telegram')) {\n    // Usuario do Telegram: chatId eh o numero antes do @\n    const chatId = wid.split('@')[0];\n    resultados.push({ json: { canal: 'telegram', chatId, mensagem: msg, task_ids: data.ids } });\n  } else if (wid.includes('@c.us') || wid.includes('@s.whatsapp.net')) {\n    // Usuario do WhatsApp\n    resultados.push({ json: { canal: 'whatsapp', chatId: wid, mensagem: msg, task_ids: data.ids } });\n  } else {\n    // Tentar ambos se tiver canais_ativos\n    if (canais.includes('telegram')) {\n      const chatId = wid.split('@')[0];\n      resultados.push({ json: { canal: 'telegram', chatId, mensagem: msg, task_ids: data.ids } });\n    }\n    if (canais.includes('whatsapp')) {\n      resultados.push({ json: { canal: 'whatsapp', chatId: wid, mensagem: msg, task_ids: data.ids } });\n    }\n  }\n});\n\nreturn resultados;"
      },
