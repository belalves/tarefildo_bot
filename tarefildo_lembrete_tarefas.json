    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.id, t.titulo, t.data_vencimento, u.whatsapp_id, u.canais_ativos\nFROM tarefas t\nJOIN usuarios u ON u.id = t.usuario_id\nWHERE t.data_vencimento = CURRENT_DATE\nAND t.status = 'PENDENTE'\nAND t.lembrete_enviado = false;",
        "options": {}
      },
