      "position": [240, 0],
      "credentials": {
        "postgres": {
          "id": "lkBdUIuFYhIvqukn",
          "name": "Neon Database"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const db = $input.first().json;\nif (db.error || !db.pendentes && db.pendentes !== 0) {\n  return [{ json: { pendentes: 0, concluidas: 0, canceladas: 0, atrasadas: 0, hoje: 0, usuarios: 0, lembretes_ativos: 0 } }];\n}\nreturn [{ json: db }];"
      },
