      "name": "GET Tarefas",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 240],
      "webhookId": "1250b570-e8ad-472f-9d79-3e6001247792"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.id, t.titulo, t.data_vencimento, t.hora_vencimento, t.status, t.lembrete_enviado, t.criado_em, u.nome as usuario, u.whatsapp_id FROM tarefas t JOIN usuarios u ON u.id = t.usuario_id WHERE t.titulo IS NOT NULL AND t.titulo != '' ORDER BY CASE t.status WHEN 'PENDENTE' THEN 1 WHEN 'AGUARDANDO_DATA' THEN 2 WHEN 'CONCLUIDA' THEN 3 WHEN 'CANCELADA' THEN 4 ELSE 5 END, t.data_vencimento ASC NULLS LAST, t.criado_em DESC LIMIT 50;",
        "options": {}
      },
      "id": "efc178fb-2672-4224-8cc1-46401a5b2345",
      "name": "DB: Tarefas",
      "type": "n8n-nodes-base.postgres",
