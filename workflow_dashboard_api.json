      "webhookId": "55785a04-a6ff-42a0-884d-37b697a40232"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT (SELECT COUNT(*) FROM tarefas t WHERE t.status = 'PENDENTE')::int as pendentes, (SELECT COUNT(*) FROM tarefas t WHERE t.status = 'CONCLUIDA')::int as concluidas, (SELECT COUNT(*) FROM tarefas t WHERE t.status = 'CANCELADA')::int as canceladas, (SELECT COUNT(*) FROM tarefas t WHERE t.status = 'PENDENTE' AND t.data_vencimento < CURRENT_DATE)::int as atrasadas, (SELECT COUNT(*) FROM tarefas t WHERE t.status = 'PENDENTE' AND t.data_vencimento = CURRENT_DATE)::int as hoje, (SELECT COUNT(*) FROM usuarios)::int as usuarios, (SELECT COUNT(*) FROM lembretes WHERE ativo = true)::int as lembretes_ativos;",
        "options": {}
      },
      "id": "70541a13-c914-4ff9-934d-b35469f8c9d2",
      "name": "DB: Stats",
      "type": "n8n-nodes-base.postgres",
